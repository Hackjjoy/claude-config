{
  "permissions": {
    "allow": [
      "Bash(prompt*)",
      "Bash(git commit *)",
      "Bash(npm install*)",
      "Read(*)",
      "Update(*)",
      "Write(*)",
      "Edit(*)",
      "Bash(docker *)",
      "Bash(cp *)",
      "Bash(cat *)",
      "Bash(gh *)",
      "Bash(gcloud *)",
      "Bash(curl *)",
      "Web Search(*)",
      "Fetch(*)",
      "Bash(mkdir *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/urgency-hint.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/urgency-hint.sh"
          }
        ]
      }
    ]
  },
  "syntaxHighlightingDisabled": true,
  "skipDangerousModePermissionPrompt": true
}
